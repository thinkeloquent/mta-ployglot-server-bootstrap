{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot.local/loader.schema.json",
  "title": "LoaderReport",
  "description": "Uniform result record produced by every loader addon run.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "discovered", "validated", "imported", "registered", "skipped", "errors"],
  "properties": {
    "name":       { "type": "string" },
    "discovered": { "type": "integer", "minimum": 0 },
    "validated":  { "type": "integer", "minimum": 0 },
    "imported":   { "type": "integer", "minimum": 0 },
    "registered": { "type": "integer", "minimum": 0 },
    "skipped":    { "type": "integer", "minimum": 0 },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["step", "error"],
        "properties": {
          "step":   { "type": "string" },
          "error":  { "type": "string" },
          "path":   { "type": "string" }
        }
      }
    },
    "details": { "type": "object", "additionalProperties": true }
  }
}
